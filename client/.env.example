# Public Firebase web app config (Firebase console → Project settings → Your apps).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Comma-separated admin emails allowed to use /admin/login (must match server ADMIN_EMAILS).
VITE_ADMIN_EMAILS=admin@example.com

# Render API base URL including /api suffix.
# Local: http://localhost:3001/api
# Production (Vercel): https://your-render-service.onrender.com/api
VITE_API_URL=http://localhost:3001/api

# Optional in dev; checkout receives keyId from GET /api/razorpay/config in production.
VITE_RAZORPAY_KEY_ID=
