NODE_ENV=development
PORT=3001

# Comma-separated browser origins allowed by CORS (no trailing slash).
# Local: http://localhost:5173
# Production: https://your-app.vercel.app
CLIENT_ORIGIN=http://localhost:5173

# Razorpay test keys (dashboard → API keys). Never commit real secrets to git.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=replace_with_test_secret
RAZORPAY_MOCK_MODE=true
ALLOW_LIVE_RAZORPAY=false

# Firebase Admin SDK (service account JSON fields — server only, never in Vercel).
FIREBASE_ADMIN_PROJECT_ID=your-firebase-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace_with_private_key\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# Must match VITE_ADMIN_EMAILS on the client.
ADMIN_EMAILS=admin@example.com
