{
  "hosting": {
    "public": "client/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "server/firebase/firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "server/firebase/storage.rules"
  }
}
